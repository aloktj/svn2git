# SVN2Git Rules File
# Maps SVN repository structure to Git repositories and branches

# Create the target Git repository
create repository platform-git
end repository

# Trunk → master branch
match /trunk/
	repository platform-git
	branch master
end match

# Tags from support branches only (PLATFORM-BLXXX format).
# Matched before generic branches; written as refs/tags/ so the converter
# creates real tag refs (names without refs/ get refs/heads/ prepended).
match /tags/(PLATFORM-BL[0-9]+[^/]*)/
	repository platform-git
	branch refs/tags/\1
end match

# Support/maintenance branches (platform-bl*) — must precede the numeric
# feature-branch rule so 'bl' names are not left to fall through.
match /branches/(platform-bl[0-9]+)/
	repository platform-git
	branch \1
end match

# Feature branches (platform-1000, platform-1001, ...)
match /branches/(platform-[0-9]+)/
	repository platform-git
	branch \1
end match

# Ignore any other paths that don't match above rules
match /
	action ignore
end match
