# SVN2Git Comprehensive Test Framework Configuration

# Repository paths
SVN_ROOT_DIR="/mnt/svn/CV"
SVN_REPO_NAME="platform"
SVN_REPO_PATH="${SVN_ROOT_DIR}/${SVN_REPO_NAME}"
GIT_OUTPUT_DIR="/mnt/git"
# Note: svn2git creates repository directory based on .rules file (platform-git)
GIT_REPO_PATH="${GIT_OUTPUT_DIR}/platform-git"

# Logging. TEST_SESSION_DIR must survive re-sourcing by child scripts —
# the orchestrator exports it so every stage logs to the same directory.
LOG_DIR="${LOG_DIR:-/tmp/svn2git_test_logs}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
TEST_SESSION_DIR="${TEST_SESSION_DIR:-${LOG_DIR}/test_${TIMESTAMP}}"

# SVN Configuration (all counts overridable from the environment,
# e.g. TRUNK_COMMITS=60 ./test_svn2git.sh for a quick run)
TOTAL_REVISIONS="${TOTAL_REVISIONS:-10247}"
NUM_REGULAR_BRANCHES="${NUM_REGULAR_BRANCHES:-51}"
NUM_SUPPORT_BRANCHES="${NUM_SUPPORT_BRANCHES:-10}"
TOTAL_BRANCHES=$((NUM_REGULAR_BRANCHES + NUM_SUPPORT_BRANCHES))
NUM_AUTHORS="${NUM_AUTHORS:-50}"
NUM_C_FILES="${NUM_C_FILES:-10}"
NUM_H_FILES="${NUM_H_FILES:-10}"

# Commit distribution
TRUNK_COMMITS="${TRUNK_COMMITS:-4000}"
FEATURE_BRANCHES_COMMITS="${FEATURE_BRANCHES_COMMITS:-5000}"
SUPPORT_BRANCHES_COMMITS="${SUPPORT_BRANCHES_COMMITS:-1247}"

# Authors configuration
AUTHORS_FILE="authors.txt"
DEFAULT_AUTHOR_DOMAIN="company.com"

# SVN2Git configuration
RULES_FILE=".rules"
SVNADMIN_PATH=$(command -v svnadmin || true)
SVN_PATH=$(command -v svn || true)
GIT_PATH=$(command -v git || true)
# The converter binary is svn-all-fast-export (built with qmake && make at
# the repo root); run_migration.sh also checks the repo root and can build it.
SVN2GIT_BINARY=$(command -v svn-all-fast-export || true)

# Build configuration
SVNADMIN_BUILD_ATTEMPTS=2
CMAKE_AVAILABLE=$(which cmake)

# Disk space requirement (in MB)
REQUIRED_DISK_SPACE=5120

# Timeouts
SVN_SETUP_TIMEOUT=600      # 10 minutes
MIGRATION_TIMEOUT=900      # 15 minutes
VALIDATION_TIMEOUT=300     # 5 minutes

# Feature flags
ENABLE_PERFORMANCE_METRICS=true
ENABLE_JSON_EXPORT=true
VERBOSE_LOGGING=false
FORCE_CLEANUP=false
